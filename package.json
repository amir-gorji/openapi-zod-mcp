{
  "name": "openapi-zod-mcp",
  "version": "1.0.0",
  "description": "Deterministic, token-free Zod v4 schema generation from OpenAPI specs — no LLM hallucinations",
  "type": "module",
  "author": "Amir Gorji",
  "license": "MIT",
  "bin": {
    "openapi-zod": "./dist/index.js",
    "openapi-zod-mcp": "./dist/mcp.js"
  },
  "exports": {
    ".": "./dist/core.js",
    "./core": "./dist/core.js"
  },
  "types": "./dist/core.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs && tsc --emitDeclarationOnly",
    "clean": "rm -rf lib",
    "test": "vitest run",
    "ts": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run ts && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "commander": "^12",
    "inquirer": "^9",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amir-gorji/openapi-zod-mcp.git"
  }
}
